# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=xxxxxx
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=xxxxxx
DEEPGRAM_API_KEY=xxxxx
DEEPGRAM_PROJECT_ID=xxxxx
ANTHROPIC_API_KEY=xxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxx
MAPBOX_API_TOKEN=xxxxx                  # server-side only (geocoding script). Secret-scope token (sk.).
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxx        # client-side (map render). Public-scope token (pk.) — domain-restricted in Mapbox dashboard.
RESOURCE_ADMIN_TOKEN=xxxxx              # server-only. Long random string. Anyone with this token + URL can insert resources.